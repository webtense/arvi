# ARVI API Environment Variables

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/arvi"

# Server
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# API Keys (future use)
# VERIFACTU_API_KEY=
# SENDGRID_API_KEY=
# REDIS_URL=

# CORS (comma separated origins)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info