datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String?
  password  String
  role      String   @default("client")
  clientId  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id           Int      @id @default(autoincrement())
  invoiceNumber String  @unique
  date         DateTime
  client       String
  description  String?
  items        Json?
  subtotal     Float
  taxTotal     Float
  total        Float
  status       String
  type         String
  hash         String?
  prevHash     String?
  finalDate    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Budget {
  id        Int      @id @default(autoincrement())
  client    String
  total     Float
  status    String
  date      DateTime
  items     Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Part {
  id        Int      @id @default(autoincrement())
  client    String
  work      String
  status    String
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Asset {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  location    String?
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Ticket {
  id          Int      @id @default(autoincrement())
  client      String
  amount      Float
  category    String
  description String?
  date        DateTime
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
